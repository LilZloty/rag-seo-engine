# ──────────────────────────────────────────────────────────────
# RAG SEO Engine — backend environment (EXAMPLE)
# Copy this file to `.env` and fill in your own values.
# NEVER commit the real `.env` (it is gitignored).
# ──────────────────────────────────────────────────────────────

# --- Core ---
ENVIRONMENT=development            # development | staging | production
API_V1_STR=/api/v1
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL (pgvector extension lives in the same DB) ---
POSTGRES_URL=postgresql://USER:PASSWORD@localhost:5432/rag_seo

# --- Vector store (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# --- Redis + Celery (optional — only if you enable them) ---
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false
USE_CELERY=false

# --- LLM provider: ollama | openai | anthropic | grok | minimax ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
MINIMAX_API_KEY=
MISTRAL_API_KEY=
KIMI_API_KEY=

# --- Embeddings: ollama (free, local) | openai ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# --- Store / brand profile (used in generated content, schema.org, storefront URLs) ---
STORE_NAME=Your Store
STORE_URL=https://www.your-domain.com
STORE_SUPPORT_EMAIL=support@your-domain.com
STORE_PHONE=
STORE_YOUTUBE_URL=
STORE_BRAND_ALIASES=

# --- Shopify ---
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WEBHOOK_SECRET=

# --- SERP / keyword data (all optional) ---
SERP_PROVIDER=serpapi              # serpapi | dataforseo
SERPAPI_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
USE_DATAFORSEO=false
SERPER_API_KEY=
WEB_SEARCH_FALLBACK=true

# --- Google Analytics 4 + Search Console (optional) ---
# Path to a service-account JSON file — keep it OUT of git.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_GA4_PROPERTY_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.your-domain.com

# --- Optional in-store sales nodes (HTTP Basic) ---
SUCURSAL_BASIC_USER=
SUCURSAL_BASIC_TOKEN=
