# Frontend (Next.js) environment — copy to `.env.local`
# Public base URL the browser uses to reach the API:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Server-side rewrite target (Next rewrites /api/* → this private URL):
BACKEND_URL=http://localhost:8000
# Storefront URL used to build product links:
NEXT_PUBLIC_STORE_URL=https://www.your-domain.com
# Store display name shown in the dashboard UI:
NEXT_PUBLIC_STORE_NAME=Your Store
