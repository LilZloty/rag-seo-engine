# Environments
.env
.env.*
# …but DO track the example templates so contributors know what to configure
!.env.example
!**/.env.example
!**/.env.local.example

# Secrets — never commit
credentials/
*.pem
*.key
*-service-account.json
google-sa.json

# Python
__pycache__/
*.py[cod]
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/

# Virtualenvs
venv/
.venv/
env/
ENV/

# Node / Next.js
node_modules/
.next/
out/
coverage/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Data — never commit real exports/dumps
*.db
*.sqlite3
*.csv
*.pdf
*.xlsx
logs/
*.log

# OS
.DS_Store
Thumbs.db
ehthumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# TypeScript build cache
tsconfig.tsbuildinfo
frontend/tsconfig.tsbuildinfo
